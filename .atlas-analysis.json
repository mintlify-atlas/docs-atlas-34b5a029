  "keyFeatures": [
    "Bilibili login via QR code or cookie authentication",
    "Local-first playlist management with cloud sync support",
    "Import playlists from NetEase Cloud Music and QQ Music",
    "Full-featured audio player with loudness equalization and gapless playback",
    "SPL lyrics format with word-by-word progress and translations",
    "Download and offline playback with metadata export",
    "Material Design 3 UI with light/dark themes and monet color extraction",
    "Desktop lyrics (floating window) on Android",
    "Play history statistics and leaderboard"
  ],
  "publicApiSurface": [
    "@bbplayer/orpheus - Audio playback module",
    "@bbplayer/splash - Lyrics parser and converter",
    "@bbplayer/image-theme-colors - Cover color extraction",
    "@bbplayer/logs - Logging utilities",
    "ExpoOrpheusModule - Native audio player bridge",
    "parseLRC() - LRC lyrics parser",
    "parseSPL() - SPL lyrics parser",
    "convertNeteaseToSPL() - NetEase lyrics converter"
  ]
